# AI Productivity Measurement Framework
# Environment Configuration

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://ai_productivity_user:your_password@localhost:5432/ai_productivity
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# API Security
API_SECRET_KEY=your-secret-key-here-change-in-production
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# AI Platform API Keys (for instrumentation)
# =============================================================================
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
COHERE_API_KEY=your_cohere_key_here

# =============================================================================
# ROI Calculator Default Configuration
# =============================================================================

# Labor Costs (USD)
AVERAGE_HOURLY_WAGE=75.00
FULLY_LOADED_LABOR_RATE=125.00  # Includes benefits, overhead, etc.

# AI Tool Costs (Annual, USD)
LICENSING_COST_ANNUAL=120000.00
IMPLEMENTATION_COST_ONETIME=50000.00
TRAINING_COST_PER_USER=500.00
ONGOING_SUPPORT_COST_ANNUAL=25000.00
INFRASTRUCTURE_COST_ANNUAL=15000.00

# ROI Assumptions
TIME_SAVED_PRODUCTIVITY_CAPTURE_RATE=0.50  # 50% of saved time becomes productive work
QUALITY_IMPROVEMENT_VALUE_MULTIPLIER=1.20  # Quality improvements worth 20% premium
ADOPTION_CURVE_MONTHS=12
TOOL_ABANDONMENT_RISK=0.10  # 10% chance
QUALITY_DEGRADATION_RISK=0.15
HIDDEN_COST_MULTIPLIER=1.25  # Account for unexpected costs

# =============================================================================
# Metrics Collection Configuration
# =============================================================================
METRICS_BUFFER_SIZE=100
METRICS_FLUSH_INTERVAL_SECONDS=60
METRICS_CALCULATION_SCHEDULE=0 2 * * *  # Daily at 2 AM (cron format)

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # Options: json, text
LOG_FILE=/var/log/ai-productivity/app.log

# =============================================================================
# Redis Configuration (Optional - for caching)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600  # 1 hour

# =============================================================================
# Monitoring & Observability
# =============================================================================
ENABLE_PROMETHEUS_METRICS=true
PROMETHEUS_PORT=9090

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_QUALITY_SCORING=true
ENABLE_AUTOMATED_FEEDBACK=true
ENABLE_BENCHMARKING=false
ENABLE_ML_PREDICTIONS=false

# =============================================================================
# Privacy & Security
# =============================================================================
HASH_USER_IDS=true  # Always hash user IDs before storage
HASH_ALGORITHM=sha256
LOG_PII=false  # Never log personally identifiable information
DATA_RETENTION_DAYS=365  # Days to keep raw interaction logs

# =============================================================================
# Dashboard Configuration
# =============================================================================
DASHBOARD_URL=http://localhost:3000
DASHBOARD_REFRESH_INTERVAL=30000  # milliseconds

# =============================================================================
# Notification Configuration
# =============================================================================
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

ENABLE_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=

# =============================================================================
# Development/Testing
# =============================================================================
ENVIRONMENT=development  # Options: development, staging, production
DEBUG=true
TESTING=false
LOAD_SAMPLE_DATA=false
