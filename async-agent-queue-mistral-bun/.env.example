# Copy to .env and fill in for the REAL provider adapters. The test suite
# (`bun test`) and the offline demo (`bun run demo`) drive the queue with an
# in-memory fake provider and need NONE of these — no keys, no network.

# Mistral Le Chat Work mode (Pro or Team plan as of May 2026).
MISTRAL_API_KEY=...
MISTRAL_WEBHOOK_SECRET=...

# OpenAI background mode (on the GPT-5.5 standard tier; no separate entitlement).
OPENAI_API_KEY=sk-...
OPENAI_WEBHOOK_SECRET=...

# Public base URL your provider webhooks are delivered to (Cloudflare tunnel,
# ngrok, Tailscale Funnel, or a real hostname). Every job is wired to
# `${WEBHOOK_BASE}/webhooks/<provider>`.
WEBHOOK_BASE=https://your-tunnel.example.com
