# Copy to .env only if you want to run the suite against a REAL OpenAI-compatible
# endpoint via the optional adapter in src/lib/openai-model.ts.
#
# The default gate, demo, and test suite run FULLY OFFLINE against a deterministic
# fake model and need NONE of these. CI has no keys and still passes.
OPENAI_API_KEY=sk-...
# Any OpenAI-compatible base URL: OpenAI, Anthropic (compat), Gemini, vLLM, Ollama.
OPENAI_BASE_URL=https://api.openai.com/v1
EVAL_MODEL=gpt-5-mini
EVAL_TEMP=0

# Toggle the fake model into a "regressed" state to watch the gate FAIL and exit
# non-zero (used to demonstrate the deploy-blocking behavior):
#   EVAL_MODEL_MODE=regressed npm run gate
EVAL_MODEL_MODE=good
