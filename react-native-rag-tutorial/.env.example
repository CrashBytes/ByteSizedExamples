# ─────────────────────────────────────────────────────────────────────────────
# Retrieval / embeddings
# ─────────────────────────────────────────────────────────────────────────────
# Voyage AI powers the production embedding provider. When VOYAGE_API_KEY is
# absent, rag-core transparently falls back to the dependency-free hashing
# embedder so the server, the on-device app, and CI all run offline.
# Get a key at https://www.voyageai.com/
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5
VOYAGE_EMBED_DIM=1024

# ─────────────────────────────────────────────────────────────────────────────
# Answer synthesis (Claude)
# ─────────────────────────────────────────────────────────────────────────────
# When ANTHROPIC_API_KEY is absent, rag-core falls back to the extractive
# synthesizer (returns the top retrieved chunks verbatim with citations) so the
# pipeline still produces grounded answers without a key.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=8787
# Comma-separated origins allowed to call the retrieval API (the Expo app origin).
CORS_ORIGINS=*

# ─────────────────────────────────────────────────────────────────────────────
# Expo app (must be EXPO_PUBLIC_* to be inlined into the client bundle)
# ─────────────────────────────────────────────────────────────────────────────
# Base URL the app uses for "Cloud" retrieval mode. Use your machine's LAN IP
# when testing on a physical device (localhost resolves to the device itself).
EXPO_PUBLIC_RAG_API_URL=http://localhost:8787
