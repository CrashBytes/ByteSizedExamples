# Copy to .env and adjust. All values are optional — with none set, the demo
# uses the console span exporter and a default service name, fully offline.

# When set, spans are shipped to this OTLP/HTTP collector endpoint instead of
# the console (setupTelemetry auto-selects the 'otlp' exporter). Point this at
# your collector's traces endpoint.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# The service.name resource attribute reported on every span. Defaults to
# "otel-mcp-agent" when unset.
# OTEL_SERVICE_NAME=otel-mcp-agent
