{
  "name": "@crashbytes/pusher-mcp-server",
  "version": "1.0.3",
  "description": "MCP server for Pusher Channels — trigger events, query channels, and manage realtime messaging from AI agents",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "pusher-mcp-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pusher",
    "realtime",
    "websockets",
    "ai",
    "claude"
  ],
  "mcpName": "io.github.CrashBytes/pusher-mcp-server",
  "author": "CrashBytes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CrashBytes/pusher-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pusher": "^5.3.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "hono": "^4.12.25",
    "form-data": "^4.0.6",
    "@hono/node-server": "^2.0.4",
    "ajv": "^8.20.0",
    "fast-uri": "^3.1.4",
    "express-rate-limit": "^8.5.2",
    "path-to-regexp": "^8.4.2",
    "qs": "^6.15.2",
    "ip-address": "^10.2.0"
  }
}
